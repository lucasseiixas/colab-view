    "# ═══════════════════════════════════════════════════════\n",
    "# CÉLULA 2 — Configurações\n",
    "# ═══════════════════════════════════════════════════════\n",
    "\n",
    "# ─── API ────────────────────────────────────────────────\n",
    "YOUTUBE_API_KEY = 'AIzaSyDB_nfOrhPZ-mJT2lN8T73XfFNmvqwu-FQ'   # Obtenha em console.cloud.google.com\n",
    "\n",
    "CHANNEL_IDS = [\n",
    "    # 'UC12bjJeaHZy2AUBvPHJU3Ug',   # BDA Volleyball\n",
    "    'UCNMg6XDhRZI2QzL4pWOvP_w' # Volleyball World\n",
